# Salin file ini jadi .env.local untuk pengembangan lokal.
# Di Vercel, isi dua nilai ini lewat Settings > Environment Variables.

# Daftar kode undangan. Format: nama:kode, dipisah koma.
# Nama menempel di kode supaya kamu tahu siapa yang punya akses.
# Nama tidak boleh mengandung koma atau titik dua (keduanya jadi pemisah).
#
# Cabut akses satu orang: hapus entrinya, lalu redeploy. Sesi yang sedang
# berjalan pun langsung mati — token menyimpan sidik jari kodenya dan
# diperiksa ulang ke daftar ini setiap request.
INVITE_CODES="budi:ganti-kode-ini,siti:ganti-juga-yang-ini"

# Kunci penandatangan cookie sesi. Minimal 16 karakter, acak.
# Buat dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Kalau nilai ini diganti, semua orang otomatis ter-logout.
AUTH_SECRET="ganti-dengan-string-acak-panjang"
